@model projectFrontednd.DAO.DoanhThuDto

@{
    ViewData["Title"] = "Sửa Doanh Thu";
}

<h1>Sửa Doanh Thu</h1>

<h4>Thông Tin Hóa Đơn</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="maHoaDon" class="control-label"></label>
                <input asp-for="maHoaDon" class="form-control" readonly />
                <span asp-validation-for="maHoaDon" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="maKhachHang" class="control-label"></label>
                <select asp-for="maKhachHang" class="form-control" asp-items="ViewBag.KhachHangList">
                    <option value="">-- Chọn khách hàng --</option>
                </select>
                <span asp-validation-for="maKhachHang" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="maXe" class="control-label"></label>
                <select asp-for="maXe" class="form-control" asp-items="ViewBag.XeList">
                    <option value="">-- Chọn xe --</option>
                </select>
                <span asp-validation-for="maXe" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="maNhanVien" class="control-label"></label>
                <select asp-for="maNhanVien" class="form-control" asp-items="ViewBag.NhanVienList">
                    <option value="">-- Chọn nhân viên --</option>
                </select>
                <span asp-validation-for="maNhanVien" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ngayThanhToan" class="control-label"></label>
                <input asp-for="ngayThanhToan" class="form-control" type="date" />
                <span asp-validation-for="ngayThanhToan" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="soTien" class="control-label"></label>
                <input asp-for="soTien" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="soTien" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Lưu" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Quay lại danh sách</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}